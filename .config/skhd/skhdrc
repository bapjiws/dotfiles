alt - b: open -a "Brave Browser"
alt - t: open -a "iTerm"
alt - m: open -a "Slack"
alt - n: open -a "Obsidian"
alt - f: open -a "Finder"

# make floating window fill left-half of screen
cmd + alt - left : yabai -m window --grid 1:2:0:0:1:1

# make floating window fill right-half of screen
cmd + alt - right  : yabai -m window --grid 1:2:1:0:1:1

# make floating window fill screen
cmd + alt - up     : yabai -m window --grid 1:1:0:0:1:1

# toggle window native fullscreen
cmd + alt - f : yabai -m window --toggle native-fullscreen
