alt - b: open -a "Brave Browser"
alt - t: open -a "iTerm"
alt - m: open -a "Slack"
alt - n: open -a "Obsidian"
alt - f: osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate'

# snap window to left half (50% width) - toggle float, position, toggle back
cmd + alt - left : yabai -m window --toggle float; yabai -m window --grid 1:2:0:0:1:1; yabai -m window --toggle bsp

# snap window to right half (50% width) - toggle float, position, toggle back
cmd + alt - right : yabai -m window --toggle float; yabai -m window --grid 1:2:1:0:1:1; yabai -m window --toggle bsp

# make window fill screen - toggle float, position, toggle back
cmd + alt - up : yabai -m window --toggle float; yabai -m window --grid 1:1:0:0:1:1; yabai -m window --toggle bsp

# toggle window native fullscreen
cmd + alt - f : yabai -m window --toggle native-fullscreen

# focus monitor
# shift + alt - x  : yabai -m display --focus recent
# shift + alt - z  : yabai -m display --focus prev
# shift + alt - c  : yabai -m display --focus next
shift + alt - 1  : yabai -m display --focus 1
shift + alt - 2  : yabai -m display --focus 2
shift + alt - 3  : yabai -m display --focus 3

# send window to monitor and follow focus
# shift + cmd - x  : yabai -m window --display recent && yabai -m display --focus recent
# shift + cmd - z  : yabai -m window --display prev && yabai -m display --focus prev
# shift + cmd - c  : yabai -m window --display next && yabai -m display --focus next
shift + cmd - 1  : yabai -m window --display 1 && yabai -m display --focus 1
shift + cmd - 2  : yabai -m window --display 2 && yabai -m display --focus 2
shift + cmd - 3  : yabai -m window --display 3 && yabai -m display --focus 3
